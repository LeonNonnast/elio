{
  "name": "@elio/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ELIO TypeScript-SDK: Public API über @elio/core (run/resume, Pack-Loader, Service-Implementierungen).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@elio/core": "workspace:*"
  }
}
