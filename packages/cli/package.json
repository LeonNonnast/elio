{
  "name": "elio",
  "version": "0.0.0",
  "type": "module",
  "description": "ELIO CLI: dünner Client über @elio/sdk (Inv. 2 — keine Engine-Logik). elio run/resume/runs, Approval als CLI-Prompt.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonnonnast/elio.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "elio": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@elio/core": "workspace:*",
    "@elio/sdk": "workspace:*",
    "@elio/engine": "workspace:*"
  }
}
